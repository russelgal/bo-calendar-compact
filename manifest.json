{
  "manifest_version": 3,
  "name": "БО Компактная шахматка",
  "version": "1.1",
  "description": "Компактный вид шахматки «Бронируй Онлайн» — скрывает заголовки категорий, «Без номера», итоги",
  "permissions": ["activeTab", "contextMenus"],
  "host_permissions": [
    "https://raw.githubusercontent.com/*",
    "https://api.github.com/*"
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://lk.bronirui-online.ru/*"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ]
}
